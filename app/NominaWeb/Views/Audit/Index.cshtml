@model IEnumerable<NominaWeb.Models.LogAuditoriaSalario>

@{
    ViewData["Title"] = "Auditoría de Salarios";
}

<h1>Auditoría de Salarios</h1>

<p class="text-muted">
    Aquí se registran los cambios (INSERT/UPDATE/DELETE) realizados en Salaries.
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Fecha</th>
            <th>Usuario</th>
            <th>EmpNo</th>
            <th>Salario</th>
            <th>Detalle</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.FechaActualiz</td>
                <td>@item.Usuario</td>
                <td>@item.EmpNo</td>
                <td>@item.Salario</td>
                <td>@item.DetalleCambio</td>
            </tr>
        }
    </tbody>
</table>