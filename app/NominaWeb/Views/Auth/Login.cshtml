<h2>Login</h2>

@if (ViewBag.Error != null)
{
    <p style="color:red">@ViewBag.Error</p>
}

<form method="post">
    <div>
        <label>Usuario</label>
        <input name="usuario" />
    </div>

    <div>
        <label>Clave</label>
        <input type="password" name="clave" />
    </div>

    <button type="submit">Ingresar</button>
</form>