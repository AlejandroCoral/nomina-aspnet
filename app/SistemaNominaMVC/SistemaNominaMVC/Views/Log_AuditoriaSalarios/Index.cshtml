@model IEnumerable<SistemaNominaMVC.Models.Log_AuditoriaSalarios>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Auditoría de Salarios - Nómina</title>
</head>
<body class="bg-slate-100 p-8">
    <div class="max-w-7xl mx-auto">
        <div class="flex justify-between items-center mb-8">
            <a asp-controller="Home" asp-action="Index" class="text-slate-500 hover:text-orange-600 flex items-center gap-2 transition-colors">
                <i class='bx bx-arrow-back text-2xl'></i> Dashboard
            </a>
            <div class="text-right">
                <h1 class="text-3xl font-black text-slate-800 italic uppercase">Log de <span class="text-orange-600">Auditoría</span></h1>
                <p class="text-xs text-slate-400 font-bold tracking-widest">HISTORIAL DE CAMBIOS DE SALARIOS</p>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-100">
            <table class="w-full text-left">
                <thead class="bg-slate-800 text-white font-medium">
                    <tr>
                        <th class="p-4 text-xs uppercase tracking-wider">ID</th>
                        <th class="p-4 text-xs uppercase tracking-wider">Usuario</th>
                        <th class="p-4 text-xs uppercase tracking-wider">Fecha</th>
                        <th class="p-4 text-xs uppercase tracking-wider">Empleado (ID)</th>
                        <th class="p-4 text-xs uppercase tracking-wider">Nuevo Salario</th>
                        <th class="p-4 text-xs uppercase tracking-wider">Detalle del Cambio</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-orange-50/50 transition-colors">
                            <td class="p-4 font-mono text-orange-600 font-bold">#@item.id</td>
                            <td class="p-4">
                                <div class="flex items-center gap-2">
                                    <i class='bx bxs-user-circle text-xl text-slate-400'></i>
                                    <span class="font-bold text-slate-700">@item.usuario</span>
                                </div>
                            </td>
                            <td class="p-4 text-slate-500 text-sm">
                                @item.fechaActualiz.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="p-4 font-bold text-slate-600 text-center">
                                @item.emp_no
                            </td>
                            <td class="p-4">
                                <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full font-bold">
                                    $@item.salario.ToString("N0")
                                </span>
                            </td>
                            <td class="p-4 text-slate-500 text-sm italic">
                                "@item.DetalleCambio"
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="mt-10 text-center p-12 bg-white rounded-2xl border-2 border-dashed border-slate-200">
                <i class='bx bx-search-alt text-6xl text-slate-300 mb-4'></i>
                <p class="text-slate-500 font-medium">No se han registrado movimientos en la auditoría todavía.</p>
            </div>
        }
    </div>
</body>
</html>