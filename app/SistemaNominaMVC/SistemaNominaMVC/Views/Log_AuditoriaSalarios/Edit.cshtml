@model SistemaNominaMVC.Models.Log_AuditoriaSalarios
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Corregir Log de Auditoría - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6 font-sans">

    <div class="bg-white w-full max-w-2xl rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-amber-500 p-8 text-white relative">
            <div class="relative z-10 flex items-center gap-4">
                <div class="bg-white/20 p-3 rounded-2xl backdrop-blur-md">
                    <i class='bx bx-edit-alt text-3xl'></i>
                </div>
                <div>
                    <h2 class="text-2xl font-black italic uppercase tracking-wider">Rectificar <span class="text-amber-900/40">Log</span></h2>
                    <p class="text-amber-50 text-[10px] font-bold uppercase tracking-[3px]">Ajuste manual de registro de seguridad</p>
                </div>
            </div>
            <i class='bx bx-shield-quarter absolute -right-4 -bottom-4 text-9xl text-white/10'></i>
        </div>

        <form asp-action="Edit" class="p-10">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-xs italic mb-6"></div>
            
            <input type="hidden" asp-for="id" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-1 tracking-widest">Usuario Responsable</label>
                    <div class="relative">
                        <i class='bx bxs-user-pin absolute left-4 top-1/2 -translate-y-1/2 text-amber-500 text-xl'></i>
                        <input asp-for="usuario" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-amber-500/10 focus:border-amber-500 transition-all font-bold text-slate-700" />
                    </div>
                    <span asp-validation-for="usuario" class="text-red-500 text-[10px]"></span>
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-1 tracking-widest">Fecha y Hora</label>
                    <div class="relative">
                        <i class='bx bx-calendar-edit absolute left-4 top-1/2 -translate-y-1/2 text-amber-500 text-xl'></i>
                        <input asp-for="fechaActualiz" type="datetime-local" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-amber-500/10 focus:border-amber-500 transition-all font-bold text-slate-700" />
                    </div>
                    <span asp-validation-for="fechaActualiz" class="text-red-500 text-[10px]"></span>
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-1 tracking-widest">ID Empleado Afec.</label>
                    <div class="relative">
                        <i class='bx bx-id-card absolute left-4 top-1/2 -translate-y-1/2 text-amber-500 text-xl'></i>
                        <input asp-for="emp_no" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-amber-500/10 focus:border-amber-500 transition-all font-bold text-slate-700" />
                    </div>
                    <span asp-validation-for="emp_no" class="text-red-500 text-[10px]"></span>
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-1 tracking-widest">Monto Salarial</label>
                    <div class="relative">
                        <i class='bx bx-dollar-circle absolute left-4 top-1/2 -translate-y-1/2 text-amber-500 text-xl'></i>
                        <input asp-for="salario" type="number" step="0.01" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-amber-500/10 focus:border-amber-500 transition-all font-bold text-slate-700" />
                    </div>
                    <span asp-validation-for="salario" class="text-red-500 text-[10px]"></span>
                </div>

                <div class="space-y-2 md:col-span-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-1 tracking-widest">Corrección de la Descripción</label>
                    <div class="relative">
                        <i class='bx bx-comment-edit absolute left-4 top-4 text-amber-500 text-xl'></i>
                        <textarea asp-for="DetalleCambio" rows="3" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-amber-500/10 focus:border-amber-500 transition-all font-medium text-slate-700"></textarea>
                    </div>
                    <span asp-validation-for="DetalleCambio" class="text-red-500 text-[10px]"></span>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 mt-10">
                <button type="submit" class="flex-[2] bg-slate-800 hover:bg-slate-900 text-white font-black py-4 rounded-2xl shadow-xl shadow-slate-200 transition-all uppercase tracking-widest text-sm flex items-center justify-center gap-2">
                    <i class='bx bx-save text-xl text-amber-400'></i> Guardar Rectificación
                </button>
                <a asp-action="Index" class="flex-1 text-center py-4 bg-slate-100 hover:bg-slate-200 text-slate-500 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest border border-slate-200">
                    Descartar
                </a>
            </div>
        </form>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>