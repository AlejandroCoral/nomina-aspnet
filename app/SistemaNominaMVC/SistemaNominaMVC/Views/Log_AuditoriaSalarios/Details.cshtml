@model SistemaNominaMVC.Models.Log_AuditoriaSalarios
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Detalle de Auditoría - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6 font-sans">

    <div class="bg-white w-full max-w-2xl rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-slate-800 p-8 text-white relative">
            <div class="relative z-10 flex items-center gap-4">
                <div class="bg-emerald-500 p-3 rounded-2xl shadow-lg shadow-emerald-900/20">
                    <i class='bx bx-file-find text-3xl'></i>
                </div>
                <div>
                    <h2 class="text-2xl font-black italic uppercase tracking-wider">Reporte de <span class="text-emerald-400">Log</span></h2>
                    <p class="text-slate-400 text-[10px] font-bold uppercase tracking-[3px]">Verificación de integridad de datos</p>
                </div>
            </div>
            <i class='bx bx-shield-quarter absolute -right-4 -bottom-4 text-9xl text-white/5'></i>
        </div>

        <div class="p-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                
                <div class="bg-slate-50 p-5 rounded-3xl border border-slate-100 space-y-4">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Usuario de Sistema</p>
                        <div class="flex items-center gap-2 text-slate-700">
                            <i class='bx bxs-user-circle text-xl text-emerald-500'></i>
                            <span class="font-bold">@Model.usuario</span>
                        </div>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Timestamp</p>
                        <div class="flex items-center gap-2 text-slate-700">
                            <i class='bx bx-calendar text-xl text-emerald-500'></i>
                            <span class="font-medium text-sm">@Model.fechaActualiz</span>
                        </div>
                    </div>
                </div>

                <div class="bg-slate-50 p-5 rounded-3xl border border-slate-100 space-y-4">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">ID Empleado</p>
                        <div class="flex items-center gap-2 text-slate-700">
                            <i class='bx bxs-id-card text-xl text-emerald-500'></i>
                            <span class="font-mono font-bold uppercase text-lg">#@Model.emp_no</span>
                        </div>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Monto Registrado</p>
                        <div class="flex items-center gap-2 text-emerald-600">
                            <i class='bx bx-money text-xl'></i>
                            <span class="font-black text-xl italic">$ @Model.salario</span>
                        </div>
                    </div>
                </div>

                <div class="md:col-span-2 bg-emerald-50/30 p-6 rounded-3xl border border-emerald-100/50">
                    <p class="text-[10px] font-black text-emerald-600 uppercase tracking-widest mb-3 flex items-center gap-2">
                        <i class='bx bx-detail text-lg'></i> Descripción de la actividad
                    </p>
                    <p class="text-slate-600 leading-relaxed font-medium">
                        @Model.DetalleCambio
                    </p>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 mt-10">
                <a asp-action="Edit" asp-route-id="@Model?.id" class="flex-1 bg-slate-800 hover:bg-slate-900 text-white text-center py-4 rounded-2xl font-black shadow-xl shadow-slate-200 transition-all uppercase tracking-widest text-xs flex items-center justify-center gap-2">
                    <i class='bx bxs-edit text-lg'></i> Corregir Log
                </a>
                
                <a asp-action="Index" class="flex-1 text-center py-4 bg-white hover:bg-slate-50 text-slate-500 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest flex items-center justify-center gap-2 border border-slate-200">
                    <i class='bx bx-arrow-back text-lg'></i> Cerrar Reporte
                </a>
            </div>
        </div>
    </div>

</body>
</html>