@model SistemaNominaMVC.Models.Log_AuditoriaSalarios
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Eliminar Auditoría - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6">

    <div class="bg-white w-full max-w-lg rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-red-700 p-8 text-white text-center relative">
            <div class="bg-white/20 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-3 border-2 border-white/30">
                <i class='bx bxs-shield-x text-4xl'></i>
            </div>
            <h2 class="text-2xl font-black uppercase italic tracking-tighter">¿Eliminar Evidencia?</h2>
            <p class="text-red-100 text-[10px] font-bold uppercase tracking-widest mt-1">Esta acción eliminará un registro de control de seguridad</p>
        </div>

        <div class="p-8">
            <div class="space-y-4 mb-8">
                <div class="bg-slate-50 p-4 rounded-2xl border border-slate-200">
                    <div class="flex justify-between items-center mb-2">
                        <p class="text-[10px] font-black text-slate-400 uppercase">Responsable</p>
                        <p class="text-sm font-bold text-slate-700">@Model.usuario</p>
                    </div>
                    <div class="flex justify-between items-center mb-2">
                        <p class="text-[10px] font-black text-slate-400 uppercase">Fecha Registro</p>
                        <p class="text-sm font-medium text-slate-600">@Model.fechaActualiz</p>
                    </div>
                    <div class="flex justify-between items-center pt-2 border-t border-slate-200">
                        <p class="text-[10px] font-black text-slate-400 uppercase">Impacto Salarial</p>
                        <p class="text-sm font-black text-red-600">$@Model.salario</p>
                    </div>
                </div>

                <div class="bg-red-50 p-4 rounded-2xl border border-red-100 italic text-xs text-red-700">
                    <p class="font-black uppercase text-[9px] mb-1 opacity-70">Motivo del registro:</p>
                    "@Model.DetalleCambio"
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="id" />
                
                <div class="flex flex-col gap-3">
                    <button type="submit" class="w-full bg-red-700 hover:bg-red-800 text-white font-black py-4 rounded-2xl shadow-xl shadow-red-100 transition-all uppercase tracking-widest text-sm flex items-center justify-center gap-2">
                        <i class='bx bxs-trash-alt text-xl'></i> Confirmar Eliminación
                    </button>
                    
                    <a asp-action="Index" class="w-full text-center py-4 bg-slate-100 hover:bg-slate-200 text-slate-500 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest">
                        Cancelar y Mantener Log
                    </a>
                </div>
            </form>
        </div>
    </div>

</body>
</html>