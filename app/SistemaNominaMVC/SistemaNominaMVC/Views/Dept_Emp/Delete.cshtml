@model SistemaNominaMVC.Models.Dept_Emp
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Eliminar Asignación - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6 font-sans">

    <div class="bg-white w-full max-w-md rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-red-500 p-8 text-white text-center relative overflow-hidden">
            <div class="absolute -right-4 -top-4 bg-red-400/20 w-32 h-32 rounded-full"></div>
            
            <div class="relative z-10">
                <div class="bg-white/20 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-3 border-2 border-white/30">
                    <i class='bx bxs-unlink text-4xl'></i>
                </div>
                <h2 class="text-2xl font-black uppercase italic tracking-tighter">¿Romper Vínculo?</h2>
                <p class="text-red-100 text-[10px] font-bold uppercase tracking-widest mt-1">Se eliminará la relación laboral en este departamento</p>
            </div>
        </div>

        <div class="p-8">
            <div class="space-y-4 mb-8">
                <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100 flex items-center justify-between group hover:bg-white hover:shadow-md transition-all">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Empleado ID</p>
                        <p class="text-lg font-black text-indigo-600"># @Model.emp_no</p>
                    </div>
                    <i class='bx bxs-user-pin text-3xl text-slate-200 group-hover:text-indigo-200 transition-colors'></i>
                </div>

                <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100 flex items-center justify-between group hover:bg-white hover:shadow-md transition-all">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Departamento ID</p>
                        <p class="text-lg font-black text-slate-700 uppercase">@Model.dept_no</p>
                    </div>
                    <i class='bx bxs-buildings text-3xl text-slate-200 group-hover:text-slate-300 transition-colors'></i>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100">
                        <p class="text-[9px] font-black text-slate-400 uppercase mb-1">Vigente Desde</p>
                        <p class="text-xs font-bold text-slate-600 italic">@Model.from_date</p>
                    </div>
                    <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100">
                        <p class="text-[9px] font-black text-slate-400 uppercase mb-1">Vigente Hasta</p>
                        <p class="text-xs font-bold text-slate-600 italic">@Model.to_date</p>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="emp_no" />
                <input type="hidden" asp-for="dept_no" />
                
                <div class="flex flex-col gap-3">
                    <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-black py-4 rounded-2xl shadow-xl shadow-red-100 transition-all uppercase tracking-widest text-sm flex items-center justify-center gap-2">
                        <i class='bx bx-trash text-xl'></i> Confirmar Baja
                    </button>
                    
                    <a asp-action="Index" class="w-full text-center py-4 bg-slate-100 hover:bg-slate-200 text-slate-500 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest border border-slate-200">
                        No, mantener asignación
                    </a>
                </div>
            </form>
        </div>
    </div>

</body>
</html>