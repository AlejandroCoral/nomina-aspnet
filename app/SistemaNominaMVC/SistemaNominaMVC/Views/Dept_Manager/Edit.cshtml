@model SistemaNominaMVC.Models.Dept_Manager
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Editar Gerencia - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6">

    <div class="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-amber-500 p-8 text-white flex justify-between items-center relative overflow-hidden">
            <div class="relative z-10">
                <h2 class="text-2xl font-black italic uppercase tracking-wider">Editar <span class="text-amber-900/40">Cargo</span></h2>
                <p class="text-amber-50 text-[10px] font-bold uppercase tracking-[3px] mt-1">Actualización de periodo directivo</p>
            </div>
            <i class='bx bxs-crown text-6xl opacity-20 absolute -right-2 -top-2'></i>
        </div>

        <form asp-action="Edit" class="p-10 space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-xs italic"></div>
            
            <input type="hidden" asp-for="emp_no" />
            <input type="hidden" asp-for="dept_no" />

            <div class="grid grid-cols-2 gap-4 mb-6">
                <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Gerente ID</p>
                    <p class="font-bold text-slate-700">@Model.emp_no</p>
                </div>
                <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Depto ID</p>
                    <p class="font-bold text-slate-700">@Model.dept_no</p>
                </div>
            </div>

            <div class="space-y-4">
                <div class="space-y-2">
                    <label class="text-xs font-black text-slate-500 uppercase ml-1 tracking-widest">Inicio de Cargo</label>
                    <div class="relative">
                        <i class='bx bx-calendar-star absolute left-4 top-1/2 -translate-y-1/2 text-amber-500 text-xl'></i>
                        <input asp-for="from_date" type="date" class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-amber-500/10 focus:border-amber-500 transition-all font-bold text-slate-700" />
                    </div>
                    <span asp-validation-for="from_date" class="text-red-500 text-xs ml-1"></span>
                </div>

                <div class="space-y-2">
                    <label class="text-xs font-black text-slate-500 uppercase ml-1 tracking-widest">Fin de Cargo</label>
                    <div class="relative">
                        <i class='bx bx-calendar-check absolute left-4 top-1/2 -translate-y-1/2 text-amber-500 text-xl'></i>
                        <input asp-for="to_date" type="date" class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-amber-500/10 focus:border-amber-500 transition-all font-bold text-slate-700" />
                    </div>
                    <span asp-validation-for="to_date" class="text-red-500 text-xs ml-1"></span>
                </div>
            </div>

            <div class="flex flex-col gap-3 pt-4">
                <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-black py-4 rounded-2xl shadow-xl shadow-amber-100 transition-all uppercase tracking-widest text-sm flex items-center justify-center gap-2">
                    <i class='bx bx-save text-xl'></i> Actualizar Nombramiento
                </button>
                <a asp-action="Index" class="w-full text-center py-4 bg-slate-100 hover:bg-slate-200 text-slate-400 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest">
                    Volver sin Cambios
                </a>
            </div>
        </form>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>