@model SistemaNominaMVC.Models.Dept_Manager
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Revocar Gerente - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6 font-sans">

    <div class="bg-white w-full max-w-md rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-red-600 p-8 text-white text-center relative overflow-hidden">
            <div class="absolute -left-4 -top-4 bg-red-400/20 w-32 h-32 rounded-full"></div>
            
            <div class="relative z-10">
                <div class="bg-white/20 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-3 border-2 border-white/30">
                    <i class='bx bxs-user-x text-4xl'></i>
                </div>
                <h2 class="text-2xl font-black uppercase italic tracking-tighter">¿Revocar Cargo?</h2>
                <p class="text-red-100 text-[10px] font-bold uppercase tracking-widest mt-1">Se eliminará al empleado como gerente del área</p>
            </div>
        </div>

        <div class="p-8">
            <div class="space-y-4 mb-8">
                <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100 flex items-center justify-between group hover:bg-white hover:shadow-md transition-all">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">ID del Gerente</p>
                        <p class="text-lg font-black text-red-600 italic"># @Model.emp_no</p>
                    </div>
                    <i class='bx bxs-id-card text-3xl text-slate-200 group-hover:text-red-200 transition-colors'></i>
                </div>

                <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100 flex items-center justify-between group hover:bg-white hover:shadow-md transition-all">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Departamento</p>
                        <p class="text-lg font-black text-slate-700 uppercase">@Model.dept_no</p>
                    </div>
                    <i class='bx bxs-buildings text-3xl text-slate-200 group-hover:text-slate-300 transition-colors'></i>
                </div>

                <div class="bg-red-50 p-5 rounded-[1.5rem] border border-red-100 border-dashed text-center">
                    <p class="text-[10px] font-black text-red-400 uppercase mb-2 tracking-widest">Periodo de Gestión Registrado</p>
                    <div class="flex items-center justify-center gap-3 text-red-700 font-bold text-xs uppercase">
                        <span>@Model.from_date</span>
                        <i class='bx bx-right-arrow-alt text-lg'></i>
                        <span>@Model.to_date</span>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="emp_no" />
                <input type="hidden" asp-for="dept_no" />
                
                <div class="flex flex-col gap-3">
                    <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-black py-4 rounded-2xl shadow-xl shadow-red-100 transition-all uppercase tracking-widest text-sm flex items-center justify-center gap-2 group">
                        <i class='bx bxs-trash text-xl group-hover:shake'></i> Confirmar Revocación
                    </button>
                    
                    <a asp-action="Index" class="w-full text-center py-4 bg-slate-100 hover:bg-slate-200 text-slate-500 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest border border-slate-200">
                        No, mantener cargo
                    </a>
                </div>
            </form>
            
            <p class="text-center text-[9px] text-slate-400 uppercase font-bold mt-6 tracking-tighter opacity-60">
                Nota: Esta acción solo elimina el cargo de gerente, no al empleado.
            </p>
        </div>
    </div>

</body>
</html>