@model SistemaNominaMVC.Models.Employee
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Perfil de Empleado - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6 font-sans">

    <div class="bg-white w-full max-w-2xl rounded-[3rem] shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-blue-600 p-10 text-white flex flex-col items-center relative">
            <div class="bg-white/20 p-4 rounded-full mb-4 border-4 border-white/30 shadow-xl">
                <i class='bx bxs-user-circle text-7xl'></i>
            </div>
            <h2 class="text-3xl font-black italic uppercase tracking-tighter text-center">
                @Model.first_name <span class="text-blue-200">@Model.last_name</span>
            </h2>
            <p class="text-blue-100 text-xs font-bold uppercase tracking-[4px] mt-2">Expediente de Colaborador</p>
            
            <div class="absolute top-6 right-6 bg-blue-800/50 px-4 py-2 rounded-2xl backdrop-blur-md">
                <p class="text-[10px] font-black opacity-60 uppercase">ID EMP</p>
                <p class="font-mono font-bold">#@Model.emp_no</p>
            </div>
        </div>

        <div class="p-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                
                <div class="space-y-4">
                    <h4 class="text-[10px] font-black text-blue-600 uppercase tracking-widest flex items-center gap-2 border-b pb-2">
                        <i class='bx bxs-id-card text-lg'></i> Identificación Personal
                    </h4>
                    
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase">Cédula / CI</p>
                        <p class="text-slate-700 font-bold">@Model.ci</p>
                    </div>

                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase">Género</p>
                        <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase @(Model.gender == "M" ? "bg-blue-100 text-blue-700" : "bg-pink-100 text-pink-700")">
                            @(Model.gender == "M" ? "Masculino" : "Femenino")
                        </span>
                    </div>

                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase">Fecha de Nacimiento</p>
                        <p class="text-slate-700 font-bold italic">@Model.birth_date</p>
                    </div>
                </div>

                <div class="space-y-4">
                    <h4 class="text-[10px] font-black text-blue-600 uppercase tracking-widest flex items-center gap-2 border-b pb-2">
                        <i class='bx bxs-briefcase text-lg'></i> Información Institucional
                    </h4>

                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase">Correo Electrónico</p>
                        <p class="text-slate-700 font-bold italic underline decoration-blue-200">@Model.correo</p>
                    </div>

                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase">Fecha de Contratación</p>
                        <p class="text-slate-700 font-bold italic">@Model.hire_date</p>
                    </div>

                    <div class="bg-blue-50 p-3 rounded-xl border border-blue-100">
                        <p class="text-[10px] font-bold text-blue-400 uppercase">Estado del Registro</p>
                        <p class="text-[10px] text-blue-600 font-black uppercase italic">Vigente en Nómina</p>
                    </div>
                </div>

            </div>

            <div class="flex gap-4 mt-12">
                <a asp-action="Edit" asp-route-id="@Model.emp_no" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white text-center py-4 rounded-2xl font-black shadow-xl shadow-blue-100 transition-all uppercase tracking-widest text-xs flex items-center justify-center gap-2 group">
                    <i class='bx bxs-edit text-lg group-hover:rotate-12 transition-transform'></i> Editar Perfil
                </a>
                
                <a asp-action="Index" class="flex-1 text-center py-4 bg-slate-100 hover:bg-slate-200 text-slate-500 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest flex items-center justify-center gap-2 border border-slate-200">
                    <i class='bx bx-arrow-back text-lg'></i> Volver
                </a>
            </div>
        </div>
    </div>

</body>
</html>