@using System.Security.Claims
@{
    Layout = null; // ESTO ELIMINA EL LAYOUT BLANCO ANTERIOR
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - Sistema de Nómina</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
</head>
<body class="bg-slate-100 font-sans">

    <div class="min-h-screen p-4 md:p-8">
        <div class="max-w-7xl mx-auto flex justify-between items-center mb-8 bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <div>
                <h1 class="text-2xl md:text-3xl font-extrabold text-slate-800">
                    Bienvenido, <span class="text-blue-600">@User.Identity.Name</span>!
                </h1>
                <p class="text-slate-500 text-sm font-medium">Panel de Control General • @DateTime.Now.ToString("dd MMM yyyy")</p>
            </div>
            <a asp-controller="Login" asp-action="Logout" class="flex items-center gap-2 bg-slate-800 hover:bg-red-600 text-white px-5 py-2.5 rounded-xl transition-all duration-300 shadow-lg shadow-slate-200">
                <i class='bx bx-log-out text-xl'></i>
                <span class="hidden md:inline">Cerrar Sesión</span>
            </a>
        </div>

        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
                <div class="bg-white p-6 rounded-2xl shadow-sm border-l-8 border-blue-500 hover:shadow-md transition-shadow">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs text-gray-400 uppercase font-black tracking-wider">Recursos Humanos</p>
                            <h3 class="text-2xl font-bold text-slate-700">Empleados</h3>
                        </div>
                        <div class="bg-blue-50 p-3 rounded-lg text-blue-500">
                            <i class='bx bxs-user-badge text-3xl'></i>
                        </div>
                    </div>
                    <a asp-controller="Employees" asp-action="Index" class="mt-4 inline-flex items-center text-blue-600 text-sm font-bold hover:gap-2 transition-all">
                        Gestionar Personal <i class='bx bx-right-arrow-alt text-lg'></i>
                    </a>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border-l-8 border-emerald-500 hover:shadow-md transition-shadow">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs text-gray-400 uppercase font-black tracking-wider">Finanzas</p>
                            <h3 class="text-2xl font-bold text-slate-700">Salarios</h3>
                        </div>
                        <div class="bg-emerald-50 p-3 rounded-lg text-emerald-500">
                            <i class='bx bxs-badge-dollar text-3xl'></i>
                        </div>
                    </div>
                    <a asp-controller="Salaries" asp-action="Index" class="mt-4 inline-flex items-center text-emerald-600 text-sm font-bold hover:gap-2 transition-all">
                        Revisar Pagos <i class='bx bx-right-arrow-alt text-lg'></i>
                    </a>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border-l-8 border-violet-500 hover:shadow-md transition-shadow">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs text-gray-400 uppercase font-black tracking-wider">Estructura</p>
                            <h3 class="text-2xl font-bold text-slate-700">Departamentos</h3>
                        </div>
                        <div class="bg-violet-50 p-3 rounded-lg text-violet-500">
                            <i class='bx bxs-briefcase text-3xl'></i>
                        </div>
                    </div>
                    <a asp-controller="Departments" asp-action="Index" class="mt-4 inline-flex items-center text-violet-600 text-sm font-bold hover:gap-2 transition-all">
                        Ver Áreas <i class='bx bx-right-arrow-alt text-lg'></i>
                    </a>
                </div>
            </div>

            <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100">
                <h2 class="text-lg font-black text-slate-800 mb-8 flex items-center gap-2">
                    <i class='bx bxs-zap text-yellow-500'></i> ACCIONES RÁPIDAS
                </h2>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <a asp-controller="Employees" asp-action="Create" class="group flex flex-col items-center p-6 bg-slate-50 rounded-2xl hover:bg-blue-600 transition-all duration-300">
                        <i class='bx bxs-user-plus text-4xl text-blue-600 group-hover:text-white mb-3'></i>
                        <span class="text-xs font-bold text-slate-600 group-hover:text-white text-center">NUEVO EMPLEADO</span>
                    </a>
                    
                    <a asp-controller="Log_AuditoriaSalarios" asp-action="Index" class="group flex flex-col items-center p-6 bg-slate-50 rounded-2xl hover:bg-orange-500 transition-all duration-300">
                        <i class='bx bx-history text-4xl text-orange-600 group-hover:text-white mb-3'></i>
                        <span class="text-xs font-bold text-slate-600 group-hover:text-white text-center">AUDITORÍA</span>
                    </a>

                    <a asp-controller="Titles" asp-action="Index" class="group flex flex-col items-center p-6 bg-slate-50 rounded-2xl hover:bg-violet-600 transition-all duration-300">
                        <i class='bx bxs-id-card text-4xl text-violet-600 group-hover:text-white mb-3'></i>
                        <span class="text-xs font-bold text-slate-600 group-hover:text-white text-center">CARGOS</span>
                    </a>

                    <a asp-controller="Dept_Manager" asp-action="Index" class="group flex flex-col items-center p-6 bg-slate-50 rounded-2xl hover:bg-indigo-600 transition-all duration-300">
                        <i class='bx bxs-crown text-4xl text-indigo-600 group-hover:text-white mb-3'></i>
                        <span class="text-xs font-bold text-slate-600 group-hover:text-white text-center">GERENTES</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>