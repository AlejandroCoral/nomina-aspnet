@model SistemaNominaMVC.Models.User
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Registro - Sistema de Nómina</title>
</head>
<body class="bg-slate-900 flex items-center justify-center h-screen p-4">

    <div class="bg-white p-8 rounded-2xl shadow-2xl w-full max-w-md">
        <div class="text-center mb-8">
            <i class='bx bxs-user-plus text-5xl text-blue-600'></i>
            <h1 class="text-2xl font-bold text-gray-800">Crear Administrador</h1>
            <p class="text-gray-500 text-sm">Regístrate para gestionar la nómina</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-3 mb-4 text-sm">
                @ViewBag.Error
            </div>
        }

        <form asp-controller="Login" asp-action="Register" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            
            <div>
                <label class="block text-xs font-bold uppercase text-gray-400 mb-1">ID de Empleado (emp_no)</label>
                <input type="number" name="emp_no" required
                       class="w-full p-3 bg-gray-50 border border-gray-200 rounded-lg outline-none focus:border-blue-500 transition-all"
                       placeholder="Usa 1, 2 o 3" />
                <p class="text-[10px] text-gray-400 mt-1 italic">* Debe existir en la tabla Employees</p>
            </div>

            <div>
                <label class="block text-xs font-bold uppercase text-gray-400 mb-1">Nombre de Usuario</label>
                <input type="text" name="usuario" required
                       class="w-full p-3 bg-gray-50 border border-gray-200 rounded-lg outline-none focus:border-blue-500 transition-all"
                       placeholder="Ej: admin123" />
            </div>

            <div>
                <label class="block text-xs font-bold uppercase text-gray-400 mb-1">Contraseña</label>
                <input type="password" name="clave" required
                       class="w-full p-3 bg-gray-50 border border-gray-200 rounded-lg outline-none focus:border-blue-500 transition-all"
                       placeholder="••••••••" />
            </div>

            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl transition-all shadow-lg shadow-blue-200">
                Crear Cuenta
            </button>
        </form>

        <div class="mt-6 text-center">
            <a asp-action="Index" class="text-sm text-blue-600 hover:underline font-medium">
                <i class='bx bx-arrow-back'></i> Volver al Inicio de Sesión
            </a>
        </div>
    </div>
</body>
</html>