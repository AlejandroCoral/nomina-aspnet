@model IEnumerable<SistemaNominaMVC.Models.Salary>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Salarios - Nómina</title>
</head>
<body class="bg-slate-100 p-8 font-sans">
    <div class="max-w-6xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
            <a asp-controller="Home" asp-action="Index" class="text-slate-500 hover:text-emerald-600 flex items-center gap-2 transition-colors font-bold uppercase text-xs tracking-widest">
                <i class='bx bx-arrow-back text-2xl'></i> Dashboard
            </a>
            <h1 class="text-3xl font-black text-slate-800 italic uppercase">Control de <span class="text-emerald-600">Salarios</span></h1>
            <div class="flex gap-4 items-center">
                <a asp-action="Create" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-2 rounded-xl font-bold shadow-lg shadow-emerald-100 transition-all flex items-center gap-2 text-sm uppercase">
                    <i class='bx bx-plus-circle text-xl'></i> Nuevo Salario
                </a>
                <div class="bg-white px-4 py-2 rounded-xl shadow-sm border border-emerald-100 text-emerald-600 font-bold text-sm">
                    Total: @Model.Count()
                </div>
            </div>
        </div>

        <div class="bg-white rounded-[2rem] shadow-xl overflow-hidden border border-gray-100">
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead class="bg-slate-800 text-white uppercase font-bold tracking-widest text-[10px]">
                        <tr>
                            <th class="p-5">ID Emp</th>
                            <th class="p-5 text-right">Monto Salarial</th>
                            <th class="p-5">Desde</th>
                            <th class="p-5">Hasta</th>
                            <th class="p-5 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-emerald-50/50 transition-colors group">
                                <td class="p-5 font-bold text-slate-700">#@item.emp_no</td>
                                <td class="p-5 text-right">
                                    <span class="font-black text-emerald-700 text-lg">
                                        $@item.salary.ToString("N0")
                                    </span>
                                </td>
                                <td class="p-5 text-slate-500 font-mono text-xs">@item.from_date</td>
                                <td class="p-5">
                                    <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase @(item.to_date == "9999-01-01" || item.to_date == null ? "bg-emerald-100 text-emerald-700" : "bg-slate-100 text-slate-400")">
                                        @(item.to_date == "9999-01-01" || item.to_date == null ? "Vigente" : item.to_date)
                                    </span>
                                </td>
                                <td class="p-5 text-center">
                                    <div class="flex justify-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <a asp-action="Edit"
                                               asp-route-empNo="@item.emp_no"
                                               asp-route-fromDate="@item.from_date"
                                               class="p-2 bg-amber-100 rounded-lg text-amber-600 hover:bg-amber-500 hover:text-white transition-all shadow-sm" title="Editar">
                                            <i class='bx bxs-edit text-lg'></i>
                                        </a>
                                        
                                        <a asp-action="Details"
                                               asp-route-empNo="@item.emp_no"
                                               asp-route-fromDate="@item.from_date"
                                               class="p-2 bg-blue-100 rounded-lg text-blue-600 hover:bg-blue-500 hover:text-white transition-all shadow-sm" title="Ver Detalles">
                                            <i class='bx bxs-spreadsheet text-lg'></i>
                                        </a>

                                        <a asp-action="Delete"
                                               asp-route-empNo="@item.emp_no"
                                               asp-route-fromDate="@item.from_date"
                                               class="p-2 bg-red-100 rounded-lg text-red-600 hover:bg-red-500 hover:text-white transition-all shadow-sm" title="Eliminar">
                                            <i class='bx bxs-trash text-lg'></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="p-20 text-center">
                    <i class='bx bx-search-alt text-6xl text-slate-200 mb-4'></i>
                    <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">No se encontraron registros salariales</p>
                </div>
            }
        </div>
        
        <p class="text-[10px] text-slate-400 font-bold uppercase text-center mt-8 tracking-[4px]">
            Sistema de Gestión de Nómina v2.0
        </p>
    </div>
</body>
</html>