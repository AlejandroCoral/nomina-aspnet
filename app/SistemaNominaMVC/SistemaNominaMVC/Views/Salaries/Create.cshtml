@model SistemaNominaMVC.Models.Salary
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Asignar Salario - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6 font-sans">

    <div class="bg-white w-full max-w-2xl rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-emerald-600 p-8 text-white flex justify-between items-center relative overflow-hidden">
            <div class="relative z-10">
                <h2 class="text-2xl font-black italic uppercase tracking-wider">Nueva <span class="text-emerald-200">Asignación</span></h2>
                <p class="text-emerald-50 text-[10px] font-bold uppercase tracking-[3px] mt-1">Registro de Compensación Salarial</p>
            </div>
            <i class='bx bx-money-withdraw text-6xl opacity-20 absolute -right-2 -top-2 rotate-12'></i>
        </div>

        <form asp-action="Create" class="p-10 space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-xs italic mb-4"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-1 tracking-widest">Número de Empleado</label>
                    <div class="relative">
                        <i class='bx bxs-user-pin absolute left-4 top-1/2 -translate-y-1/2 text-emerald-600 text-xl'></i>
                        <input asp-for="emp_no" class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-emerald-500/10 focus:border-emerald-500 transition-all font-bold text-slate-700" placeholder="Ej: 10001" />
                    </div>
                    <span asp-validation-for="emp_no" class="text-red-500 text-[10px]"></span>
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-1 tracking-widest">Monto Anual / Mensual</label>
                    <div class="relative">
                        <i class='bx bx-dollar absolute left-4 top-1/2 -translate-y-1/2 text-emerald-600 text-xl'></i>
                        <input asp-for="salary" type="number" class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-emerald-500/10 focus:border-emerald-500 transition-all font-black text-slate-700" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="salary" class="text-red-500 text-[10px]"></span>
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-1 tracking-widest">Vigente Desde</label>
                    <div class="relative">
                        <i class='bx bx-calendar-plus absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl'></i>
                        <input asp-for="from_date" type="date" class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-emerald-500/10 focus:border-emerald-500 transition-all font-bold text-slate-700" />
                    </div>
                    <span asp-validation-for="from_date" class="text-red-500 text-[10px]"></span>
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase ml-1 tracking-widest">Vigente Hasta</label>
                    <div class="relative">
                        <i class='bx bx-calendar-check absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl'></i>
                        <input asp-for="to_date" type="date" class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-emerald-500/10 focus:border-emerald-500 transition-all font-bold text-slate-700" />
                    </div>
                    <span asp-validation-for="to_date" class="text-red-500 text-[10px]"></span>
                </div>

            </div>

            <div class="flex flex-col sm:flex-row gap-4 pt-6">
                <button type="submit" class="flex-[2] bg-emerald-600 hover:bg-emerald-700 text-white font-black py-4 rounded-2xl shadow-xl shadow-emerald-100 transition-all uppercase tracking-widest text-sm flex items-center justify-center gap-2">
                    <i class='bx bx-save text-xl'></i> Registrar Salario
                </button>
                <a asp-action="Index" class="flex-1 text-center py-4 bg-slate-100 hover:bg-slate-200 text-slate-500 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest border border-slate-200">
                    Cancelar
                </a>
            </div>
        </form>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>