@model SistemaNominaMVC.Models.Salary
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Detalles Salariales - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6 font-sans">

    <div class="bg-white w-full max-w-lg rounded-[3rem] shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-emerald-600 p-8 text-white relative">
            <div class="relative z-10">
                <p class="text-[10px] font-black uppercase tracking-[4px] opacity-70 mb-1">Registro de Nómina</p>
                <h2 class="text-3xl font-black italic uppercase">Ficha <span class="text-emerald-200">Salarial</span></h2>
            </div>
            <i class='bx bx-trending-up absolute -right-4 -bottom-4 text-9xl text-white/10'></i>
        </div>

        <div class="p-10">
            <div class="text-center mb-8 p-6 bg-emerald-50 rounded-[2rem] border border-emerald-100">
                <p class="text-[10px] font-black text-emerald-600 uppercase tracking-[3px] mb-2">Compensación Actual</p>
                <div class="flex items-center justify-center gap-2">
                    <span class="text-2xl font-bold text-emerald-400">$</span>
                    <h3 class="text-5xl font-black text-emerald-700 tracking-tighter">@Html.DisplayFor(model => model.salary)</h3>
                </div>
            </div>

            <div class="space-y-4">
                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <div class="flex items-center gap-3">
                        <div class="bg-white p-2 rounded-xl shadow-sm">
                            <i class='bx bxs-user-pin text-emerald-600 text-xl'></i>
                        </div>
                        <span class="text-xs font-black text-slate-400 uppercase tracking-widest">ID Empleado</span>
                    </div>
                    <span class="font-bold text-slate-700"># @Model.emp_no</span>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Válido Desde</p>
                        <p class="font-bold text-slate-700 flex items-center gap-2 italic text-sm">
                            <i class='bx bx-calendar-event text-emerald-500'></i> @Model.from_date
                        </p>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Válido Hasta</p>
                        <p class="font-bold text-slate-700 flex items-center gap-2 italic text-sm">
                            <i class='bx bx-calendar-check text-emerald-500'></i> @Model.to_date
                        </p>
                    </div>
                </div>
            </div>

            <div class="flex gap-4 mt-10">
                <a asp-action="Edit"
                       asp-route-empNo="@Model.emp_no"
                       asp-route-fromDate="@Model.from_date"
                       class="flex-1 bg-emerald-600 hover:bg-emerald-700 text-white text-center py-4 rounded-2xl font-black shadow-xl shadow-emerald-100 transition-all uppercase tracking-widest text-xs flex items-center justify-center gap-2">
                    <i class='bx bxs-edit text-lg'></i> Editar Salario
                </a>
                
                <a asp-action="Index" class="flex-1 text-center py-4 bg-white hover:bg-slate-50 text-slate-500 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest flex items-center justify-center gap-2 border border-slate-200">
                    <i class='bx bx-arrow-back text-lg'></i> Volver
                </a>
            </div>
            
            <p class="text-center text-[9px] text-slate-400 uppercase font-bold mt-8 tracking-widest opacity-50">
                Historial Salarial Auditado - Sistema Nómina 2026
            </p>
        </div>
    </div>

</body>
</html>