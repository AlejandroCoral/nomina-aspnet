@model SistemaNominaMVC.Models.Salary
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Ajustar Salario - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6 font-sans">

    <div class="bg-white w-full max-w-lg rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-amber-500 p-8 text-white flex justify-between items-center relative overflow-hidden">
            <div class="relative z-10">
                <h2 class="text-2xl font-black italic uppercase tracking-wider text-amber-950">Ajuste <span class="text-white">Salarial</span></h2>
                <p class="text-amber-50 text-[10px] font-bold uppercase tracking-[3px] mt-1">Actualización de compensación</p>
            </div>
            <i class='bx bx-edit-alt text-6xl opacity-20 absolute -right-2 -top-2'></i>
        </div>

        <form asp-action="Edit" method="post" class="p-10">
            <div asp-validation-summary="ModelOnly" class="bg-red-50 border-l-4 border-red-500 p-4 text-red-700 text-xs italic mb-6 rounded-r-xl"></div>
            
            <input type="hidden" asp-for="emp_no" />
            <input type="hidden" asp-for="from_date" />

            <div class="space-y-6">
                <div class="flex items-center gap-4 p-4 bg-slate-50 rounded-2xl border border-slate-100 mb-2 group hover:bg-white transition-all shadow-inner">
                    <div class="bg-amber-100 p-2 rounded-xl text-amber-600">
                        <i class='bx bxs-user-pin text-xl'></i>
                    </div>
                    <div>
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Empleado ID</p>
                        <p class="font-black text-slate-700">#@Model.emp_no</p>
                    </div>
                    <div class="ml-auto text-right border-l pl-4 border-slate-200">
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Vigente Desde</p>
                        <p class="font-bold text-amber-600 text-xs italic">@Model.from_date</p>
                    </div>
                </div>

                <div class="space-y-2">
                    <label asp-for="salary" class="text-[10px] font-black text-slate-400 uppercase ml-1 tracking-widest">Nuevo Monto Salarial</label>
                    <div class="relative">
                        <i class='bx bx-dollar absolute left-4 top-1/2 -translate-y-1/2 text-emerald-600 text-2xl'></i>
                        <input asp-for="salary" type="number" step="0.01" class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-amber-500/10 focus:border-amber-500 transition-all font-black text-2xl text-slate-700" />
                    </div>
                    <span asp-validation-for="salary" class="text-red-500 text-[10px] font-bold ml-1"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="to_date" class="text-[10px] font-black text-slate-400 uppercase ml-1 tracking-widest">Vigencia Hasta</label>
                    <div class="relative">
                        <i class='bx bx-calendar-check absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl'></i>
                        <input asp-for="to_date" class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-amber-500/10 focus:border-amber-500 transition-all font-bold text-slate-700" placeholder="YYYY-MM-DD" />
                    </div>
                    <span asp-validation-for="to_date" class="text-red-500 text-[10px] font-bold ml-1"></span>
                </div>
            </div>

            <div class="flex flex-col gap-3 mt-10">
                <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-black py-4 rounded-2xl shadow-xl shadow-amber-100 transition-all uppercase tracking-widest text-sm flex items-center justify-center gap-2">
                    <i class='bx bx-check-double text-xl'></i> Aplicar Aumento / Cambio
                </button>
                <a asp-action="Index" class="w-full text-center py-4 bg-slate-100 hover:bg-slate-200 text-slate-500 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest border border-slate-200">
                    Cancelar
                </a>
            </div>
        </form>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>