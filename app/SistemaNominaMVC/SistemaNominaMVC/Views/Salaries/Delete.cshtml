@model SistemaNominaMVC.Models.Salary
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Eliminar Salario - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6 font-sans">

    <div class="bg-white w-full max-w-md rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-red-600 p-8 text-white text-center relative overflow-hidden">
            <div class="bg-white/20 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-3 border-2 border-white/30 relative z-10">
                <i class='bx bx-money text-4xl'></i>
            </div>
            <h2 class="text-2xl font-black uppercase italic tracking-tighter relative z-10">¿Eliminar Registro?</h2>
            <p class="text-red-100 text-[10px] font-bold uppercase tracking-widest mt-1 relative z-10">Esta acción es irreversible y afectará el historial</p>
            
            <i class='bx bx-trending-down absolute -right-4 -bottom-4 text-8xl text-black/10'></i>
        </div>

        <div class="p-8">
            <div class="space-y-4 mb-8">
                <div class="bg-slate-50 p-6 rounded-3xl border border-slate-100 text-center">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Monto del Salario</p>
                    <h3 class="text-4xl font-black text-red-600 italic">
                        $@Html.DisplayFor(model => model.salary)
                    </h3>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-[2px]">Emp #</p>
                        <p class="font-bold text-slate-700">@Model.emp_no</p>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-[2px]">Válido hasta</p>
                        <p class="font-bold text-slate-700 italic">@Model.to_date</p>
                    </div>
                </div>
                
                <div class="p-4 bg-red-50 rounded-2xl border border-red-100 border-dashed">
                    <p class="text-[10px] font-bold text-red-700 uppercase flex items-center gap-2">
                        <i class='bx bxs-error-circle'></i> Nota importante
                    </p>
                    <p class="text-[11px] text-red-600 mt-1">
                        Se eliminará el registro vigente desde el <b>@Model.from_date</b>. Verifique los reportes fiscales antes de proceder.
                    </p>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="emp_no" />
                <input type="hidden" asp-for="from_date" />
                
                <div class="flex flex-col gap-3">
                    <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-black py-4 rounded-2xl shadow-xl shadow-red-100 transition-all uppercase tracking-widest text-sm flex items-center justify-center gap-2 group">
                        <i class='bx bxs-trash-alt text-xl group-hover:animate-bounce'></i> Confirmar Baja
                    </button>
                    
                    <a asp-action="Index" class="w-full text-center py-4 bg-slate-100 hover:bg-slate-200 text-slate-500 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest border border-slate-200">
                        No, mantener registro
                    </a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>