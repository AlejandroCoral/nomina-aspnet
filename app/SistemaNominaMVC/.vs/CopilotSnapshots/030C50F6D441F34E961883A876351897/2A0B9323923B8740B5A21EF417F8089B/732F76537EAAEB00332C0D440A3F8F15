@model SistemaNominaMVC.Models.Department
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Nuevo Departamento - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6">

    <div class="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-indigo-600 p-8 text-white flex justify-between items-center">
            <div>
                <h2 class="text-2xl font-black italic uppercase tracking-wider">Nueva <span class="text-indigo-200">Área</span></h2>
                <p class="text-indigo-100 text-xs font-medium uppercase tracking-widest mt-1">Registro de Departamentos</p>
            </div>
            <i class='bx bxs-buildings text-5xl opacity-30'></i>
        </div>

        <form asp-action="Create" method="post" class="p-10 space-y-6">
            <div asp-validation-summary="ModelOnly" class="bg-red-50 border-l-4 border-red-500 p-4 text-red-700 text-xs italic mb-4 rounded-r-xl"></div>

            @* <input type="hidden" asp-for="dept_no" /> *@

            <div class="space-y-2">
                <label asp-for="dept_name" class="text-xs font-black text-slate-500 uppercase ml-1 tracking-tighter">Nombre del Departamento</label>
                <div class="relative">
                    <i class='bx bx-rename absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl'></i>
                    <input asp-for="dept_name" class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all font-medium text-slate-700" placeholder="Ej: Recursos Humanos" />
                </div>
                <span asp-validation-for="dept_name" class="text-red-500 text-[10px] font-bold ml-1"></span>
            </div>

            <div class="flex flex-col gap-3 pt-4">
                <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black py-4 rounded-2xl shadow-xl shadow-indigo-100 transition-all uppercase tracking-widest text-sm flex items-center justify-center gap-2">
                    <i class='bx bx-save text-xl'></i> Guardar Departamento
                </button>
                <a asp-action="Index" class="w-full text-center py-4 bg-slate-100 hover:bg-slate-200 text-slate-500 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest">
                    Cancelar y Volver
                </a>
            </div>
        </form>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>