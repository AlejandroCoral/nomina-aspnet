@model SistemaNominaMVC.Models.Dept_Emp
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Detalles de Asignación - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6 font-sans">

    <div class="bg-white w-full max-w-lg rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-cyan-600 p-8 text-white relative overflow-hidden">
            <div class="relative z-10">
                <p class="text-[10px] font-black uppercase tracking-[4px] opacity-70 mb-1">Consulta de Registro</p>
                <h2 class="text-3xl font-black italic uppercase">Detalles de <span class="text-cyan-200">Vínculo</span></h2>
            </div>
            <i class='bx bxs-spreadsheet absolute -right-4 -bottom-4 text-9xl text-white/10'></i>
        </div>

        <div class="p-8">
            <div class="grid grid-cols-1 gap-4 mb-8">
                
                <div class="flex items-center justify-between p-5 bg-slate-50 rounded-2xl border border-slate-100 group hover:bg-white hover:shadow-md transition-all">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">ID Empleado</p>
                        <h3 class="text-2xl font-black text-cyan-700"># @Model.emp_no</h3>
                    </div>
                    <div class="bg-cyan-100 p-3 rounded-xl text-cyan-600">
                        <i class='bx bxs-user-detail text-3xl'></i>
                    </div>
                </div>

                <div class="flex items-center justify-between p-5 bg-slate-50 rounded-2xl border border-slate-100 group hover:bg-white hover:shadow-md transition-all">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Código Departamento</p>
                        <h3 class="text-2xl font-black text-slate-800 uppercase">@Model.dept_no</h3>
                    </div>
                    <div class="bg-slate-200 p-3 rounded-xl text-slate-400">
                        <i class='bx bxs-buildings text-3xl'></i>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100 text-center">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Fecha Inicio</p>
                        <p class="font-bold text-slate-700 italic">@Model.from_date</p>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100 text-center">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Fecha Fin</p>
                        <p class="font-bold text-slate-700 italic">@Model.to_date</p>
                    </div>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-3">
                <a asp-action="Edit"
                       asp-route-empNo="@Model.emp_no"
                       asp-route-deptNo="@Model.dept_no"
                       class="flex-[2] bg-cyan-600 hover:bg-cyan-700 text-white text-center py-4 rounded-2xl font-black shadow-xl shadow-cyan-100 transition-all uppercase tracking-widest text-xs flex items-center justify-center gap-2">
                    <i class='bx bxs-edit text-lg'></i> Editar Asignación
                </a>
                
                <a asp-action="Index" class="flex-1 text-center py-4 bg-white hover:bg-slate-50 text-slate-500 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest flex items-center justify-center gap-2 border border-slate-200">
                    <i class='bx bx-undo text-lg'></i> Volver
                </a>
            </div>
            
            <p class="text-center text-[9px] text-slate-400 uppercase font-bold mt-8 tracking-[2px] opacity-50">
                Historial de Movimientos de Personal
            </p>
        </div>
    </div>

</body>
</html>