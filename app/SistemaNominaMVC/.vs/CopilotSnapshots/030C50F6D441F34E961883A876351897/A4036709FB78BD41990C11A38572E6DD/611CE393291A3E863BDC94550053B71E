@model SistemaNominaMVC.Models.Department
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Editar Departamento - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6 font-sans">

    <div class="bg-white w-full max-w-lg rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-amber-500 p-8 text-white flex justify-between items-center relative overflow-hidden">
            <div class="relative z-10">
                <h2 class="text-2xl font-black italic uppercase tracking-wider text-amber-950">Editar <span class="text-white">Área</span></h2>
                <p class="text-amber-50 text-[10px] font-bold uppercase tracking-[3px] mt-1">ID del Registro: @Model.dept_no</p>
            </div>
            <i class='bx bxs-edit-alt text-6xl opacity-20 absolute -right-2 -top-2'></i>
        </div>

        <form asp-action="Edit" method="post" class="p-10 space-y-6">
            <div asp-validation-summary="ModelOnly" class="bg-red-50 border-l-4 border-red-500 p-4 text-red-700 text-xs italic mb-4 rounded-r-xl"></div>
            
            <input type="hidden" asp-for="dept_no" />

            <div class="space-y-2">
                <label asp-for="dept_name" class="text-[10px] font-black text-slate-400 uppercase ml-1 tracking-widest">Nombre del Departamento</label>
                <div class="relative">
                    <i class='bx bx-buildings absolute left-4 top-1/2 -translate-y-1/2 text-amber-500 text-xl'></i>
                    <input asp-for="dept_name" class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-amber-500/10 focus:border-amber-500 transition-all font-bold text-slate-700" placeholder="Nombre del área..." />
                </div>
                <span asp-validation-for="dept_name" class="text-red-500 text-[10px] ml-1 font-bold"></span>
            </div>

            <div class="flex flex-col gap-3 pt-4">
                <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-black py-4 rounded-2xl shadow-xl shadow-amber-100 transition-all uppercase tracking-widest text-sm flex items-center justify-center gap-2">
                    <i class='bx bx-check-double text-xl'></i> Guardar Cambios
                </button>
                <a asp-action="Index" class="w-full text-center py-4 bg-slate-100 hover:bg-slate-200 text-slate-400 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest border border-slate-200">
                    Descartar y Volver
                </a>
            </div>
        </form>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>