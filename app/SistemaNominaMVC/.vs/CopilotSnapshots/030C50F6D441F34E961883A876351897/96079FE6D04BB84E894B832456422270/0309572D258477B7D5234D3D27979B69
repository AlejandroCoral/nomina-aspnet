@model SistemaNominaMVC.Models.Dept_Emp
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Asignar Departamento - Sistema de Nómina</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen p-6">

    <div class="bg-white w-full max-w-2xl rounded-3xl shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-cyan-500 p-8 text-white flex justify-between items-center">
            <div>
                <h2 class="text-2xl font-black italic uppercase tracking-wider">Asignar <span class="text-cyan-100">Área</span></h2>
                <p class="text-cyan-50 text-[10px] font-bold uppercase tracking-[3px] mt-1">Vinculación de Empleado y Departamento</p>
            </div>
            <i class='bx bx-link-external text-5xl opacity-30'></i>
        </div>

        <form asp-action="Create" class="p-10 grid grid-cols-1 md:grid-cols-2 gap-6">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-xs italic col-span-full"></div>

            <div class="space-y-2">
                <label class="text-xs font-black text-slate-500 uppercase ml-1 tracking-widest">ID Empleado</label>
                <div class="relative">
                    <i class='bx bxs-user absolute left-4 top-1/2 -translate-y-1/2 text-cyan-500 text-xl'></i>
                    <input asp-for="emp_no" class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-cyan-500/10 focus:border-cyan-500 transition-all font-bold text-slate-700" placeholder="Ej: 10001" />
                </div>
                <span asp-validation-for="emp_no" class="text-red-500 text-xs ml-1"></span>
            </div>

            <div class="space-y-2">
                <label class="text-xs font-black text-slate-500 uppercase ml-1 tracking-widest">Código Dept</label>
                <div class="relative">
                    <i class='bx bxs-buildings absolute left-4 top-1/2 -translate-y-1/2 text-cyan-500 text-xl'></i>
                    <input asp-for="dept_no" class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-cyan-500/10 focus:border-cyan-500 transition-all font-bold text-slate-700" placeholder="Ej: d001" />
                </div>
                <span asp-validation-for="dept_no" class="text-red-500 text-xs ml-1"></span>
            </div>

            <div class="space-y-2">
                <label class="text-xs font-black text-slate-500 uppercase ml-1 tracking-widest">Fecha Inicio</label>
                <input asp-for="from_date" type="date" class="w-full px-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-cyan-500/10 focus:border-cyan-500 transition-all font-medium text-slate-700" />
                <span asp-validation-for="from_date" class="text-red-500 text-xs ml-1"></span>
            </div>

            <div class="space-y-2">
                <label class="text-xs font-black text-slate-500 uppercase ml-1 tracking-widest">Fecha Fin</label>
                <input asp-for="to_date" type="date" class="w-full px-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-cyan-500/10 focus:border-cyan-500 transition-all font-medium text-slate-700" />
                <span asp-validation-for="to_date" class="text-red-500 text-xs ml-1"></span>
            </div>

            <div class="col-span-full flex flex-col gap-3 pt-4">
                <button type="submit" class="w-full bg-cyan-500 hover:bg-cyan-600 text-white font-black py-4 rounded-2xl shadow-xl shadow-cyan-100 transition-all uppercase tracking-widest text-sm flex items-center justify-center gap-2">
                    <i class='bx bx-check-shield text-xl'></i> Crear Asignación
                </button>
                <a asp-action="Index" class="w-full text-center py-4 bg-slate-100 hover:bg-slate-200 text-slate-400 font-bold rounded-2xl transition-all text-xs uppercase tracking-widest">
                    Cancelar y Volver
                </a>
            </div>
        </form>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>
