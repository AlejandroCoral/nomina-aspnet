@model IEnumerable<SistemaNominaMVC.Models.Dept_Manager>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Gerentes de Departamento - Nómina</title>
</head>
<body class="bg-slate-100 p-8">
    <div class="max-w-5xl mx-auto">
        <div class="flex justify-between items-center mb-8">
            <a asp-controller="Home" asp-action="Index" class="text-slate-500 hover:text-indigo-600 flex items-center gap-2 transition-colors">
                <i class='bx bx-arrow-back text-2xl'></i> Dashboard
            </a>
            <div class="text-right">
                <h1 class="text-3xl font-black text-slate-800 italic uppercase">Cuerpo <span class="text-indigo-600">Directivo</span></h1>
                <p class="text-xs text-slate-400 font-bold tracking-widest">GERENTES POR DEPARTAMENTO</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            @foreach (var item in Model)
            {
                <div class="bg-white p-6 rounded-2xl shadow-sm border-t-4 border-indigo-500 flex items-center justify-between hover:shadow-md transition-all">
                    <div class="flex items-center gap-4">
                        <div class="bg-indigo-50 p-4 rounded-xl text-indigo-600">
                            <i class='bx bxs-crown text-3xl'></i>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-slate-700">Empleado #@item.emp_no</h3>
                            <p class="text-sm text-indigo-600 font-bold">Departamento ID: @item.dept_no</p>
                            <p class="text-[10px] text-gray-400 mt-1 uppercase font-medium">Gestión: @item.from_date - @item.to_date</p>
                        </div>
                    </div>
                    <div class="flex flex-col gap-2">
                        <a asp-action="Edit" asp-route-id="@item.emp_no" class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all"><i class='bx bxs-edit text-xl'></i></a>
                        <a asp-action="Delete" asp-route-id="@item.emp_no" class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all"><i class='bx bxs-trash text-xl'></i></a>
                    </div>
                </div>
            }
        </div>
    </div>
</body>
</html>